generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  screenshots  Screenshot[]
  frames       Frame[]
  boards       Board[]
}

// Один аудит/проект = одна доска. Пользователь заводит новую доску под
// каждую конкурентную задачу вместо одной бесконечной свалки (см. SPEC §12).
model Board {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String

  createdAt   DateTime     @default(now())

  screenshots Screenshot[]
  frames      Frame[]

  @@index([userId])
}

model Screenshot {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // файл
  storageKey  String   @unique
  width       Int
  height      Int
  mimeType    String   @default("image/png")

  // контекст
  sourceUrl   String
  pageTitle   String
  capturedAt  DateTime

  // позиция на доске
  boardX      Float    @default(0)
  boardY      Float    @default(0)
  boardScale  Float    @default(1)

  createdAt   DateTime @default(now())

  @@index([userId, capturedAt])
  @@index([boardId])
}

// Именованная зона на доске для визуальной группировки скриншотов при
// сравнении паттернов (см. SPEC §12.2). Первая версия — чисто визуальный
// маркер: принадлежность скриншотов зоне не отслеживается.
model Frame {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  name      String
  x         Float
  y         Float
  width     Float
  height    Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([boardId])
}
